# ==========================================
# WorkOS Production Environment Variables
# ==========================================

# 1. Environment
ENVIRONMENT=production

# 2. Database (Neon PostgreSQL)
# Format: postgresql://[user]:[password]@[neon_hostname]/[dbname]
DATABASE_URL=

# 3. Redis (Upstash)
# Format: rediss://default:[password]@[upstash_hostname]:[port]
REDIS_URL=

# 4. Security (Generate strong random strings)
JWT_SECRET=
JWT_REFRESH_SECRET=

# 5. Frontend & CORS
# The URL of your deployed Next.js Vercel app
CORS_ORIGINS=https://your-frontend.vercel.app

# 6. AI (Gemini)
GEMINI_API_KEY=

# 7. Jira Integration (Optional)
JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=
